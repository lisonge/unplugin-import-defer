      "types": "./dist/astro.d.mts",
      "import": "./dist/astro.mjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.mts",
      "import": "./dist/esbuild.mjs"
    },
    "./farm": {
      "types": "./dist/farm.d.mts",
      "import": "./dist/farm.mjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.mts",
      "import": "./dist/nuxt.mjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.mts",
      "import": "./dist/rollup.mjs"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.mts",
      "import": "./dist/rolldown.mjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.mts",
      "import": "./dist/rspack.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "import": "./dist/webpack.mjs"
    },
    "./unloader": {
      "types": "./dist/unloader.d.mts",
      "import": "./dist/unloader.mjs"
    },
    "./bun": {
      "types": "./dist/bun.d.mts",
      "import": "./dist/bun.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsc --noEmit",
    "build": "tsdown",
    "dev": "tsdown -w",
    "test": "vitest"
  },
  "peerDependencies": {
    "@farmfe/core": ">=1",
    "@nuxt/kit": "^3",
    "@nuxt/schema": "^3",
    "esbuild": "*",
    "rolldown": ">=1",
    "rollup": "^3 || ^4",
    "vite": ">=3",
    "webpack": "^4 || ^5"
  },
  "peerDependenciesMeta": {
    "@farmfe/core": {
      "optional": true
    },
    "@nuxt/kit": {
      "optional": true
    },
    "@nuxt/schema": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "oxc-parser": "^0.129.0",
    "unplugin": "^3.0.0",
    "zimmerframe": "^1.1.4"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "tsdown": "0.22.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
