{
  "name": "unplugin-import-defer",
  "type": "module",
  "version": "0.2.0",
  "description": "Transform import defer syntax to dynamic import()",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lisonge/unplugin-import-defer.git"
  },
  "homepage": "https://github.com/lisonge/unplugin-import-defer#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "rollup",
    "rolldown",
    "esbuild",
    "rspack",
    "farm",
    "bun",
    "transform",
    "import-defer"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
